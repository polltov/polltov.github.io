---
import { site } from '../config/site';

const navLeft = [
  { label: 'Работы', href: '#works' },
  { label: 'Услуги', href: '#services' },
];
const navRight = [
  { label: 'О студии', href: '#about' },
  { label: 'Контакты', href: '#contacts' },
];
---

<header class="sticky top-0 z-40 border-b border-ink/90 bg-cream/85 backdrop-blur-md">
  <div class="mx-auto grid max-w-[1400px] grid-cols-[1fr_auto_1fr] items-center gap-6 px-6 py-4 md:px-10">
    <nav class="flex items-center gap-6 md:gap-8">
      {navLeft.map((item) => (
        <a
          href={item.href}
          class="label text-ink/80 transition-colors hover:text-ink"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a
      href="/"
      class="relative inline-block font-display text-[28px] leading-none tracking-tight text-ink md:text-[32px]"
      aria-label="RES prod"
    >
      <span class="relative z-10">RES</span>
      <svg
        viewBox="0 0 520 80"
        class="pointer-events-none absolute left-[-6%] right-[-6%] top-[52%] z-20 w-[112%] -translate-y-1/2"
        aria-hidden="true"
      >
        <path
          d="M8 48 C 80 8, 180 76, 260 32 S 440 76, 512 28"
          fill="none"
          stroke="currentColor"
          stroke-width="9"
          stroke-linecap="round"
        />
      </svg>
    </a>
    <nav class="flex items-center justify-end gap-6 md:gap-8">
      {navRight.map((item) => (
        <a
          href={item.href}
          class="label text-ink/80 transition-colors hover:text-ink"
        >
          {item.label}
        </a>
      ))}
      <a
        href={site.telegram}
        target="_blank"
        rel="noopener"
        class="btn-ink hidden md:inline-flex"
      >
        Telegram
      </a>
    </nav>
  </div>
</header>
