---

<div id="cursor-follower" aria-hidden="true"></div>

<style is:global>
  #cursor-follower {
    position: fixed;
    top: 0;
    left: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-lime);
    pointer-events: none;
    z-index: 90;
    opacity: 0;
    transform: translate3d(-50px, -50px, 0);
    transition: opacity 220ms ease, width 220ms cubic-bezier(0.2, 0.85, 0.25, 1),
      height 220ms cubic-bezier(0.2, 0.85, 0.25, 1),
      background 220ms ease;
    will-change: transform;
    mix-blend-mode: multiply;
  }
  #cursor-follower.is-active {
    opacity: 0.85;
  }
  #cursor-follower.is-large {
    width: 64px;
    height: 64px;
    opacity: 0.7;
  }
  /* Only render on devices with a fine pointer (mouse/trackpad) */
  @media not all and (hover: hover), not all and (pointer: fine) {
    #cursor-follower { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    #cursor-follower { display: none; }
  }
</style>

<script is:inline>
  (function () {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const el = document.getElementById('cursor-follower');
    if (!el) return;

    let targetX = window.innerWidth / 2;
    let targetY = window.innerHeight / 2;
    let x = targetX;
    let y = targetY;
    let activated = false;

    const HALF = () => el.offsetWidth / 2;

    window.addEventListener('mousemove', (e) => {
      targetX = e.clientX;
      targetY = e.clientY;
      if (!activated) {
        activated = true;
        el.classList.add('is-active');
      }
    });

    document.addEventListener('mouseleave', () => el.classList.remove('is-active'));
    document.addEventListener('mouseenter', () => el.classList.add('is-active'));

    const interactiveSelector = 'a, button, [data-lead-trigger], [role="button"], input, select, textarea';
    document.addEventListener('mouseover', (e) => {
      if (e.target.closest && e.target.closest(interactiveSelector)) {
        el.classList.add('is-large');
      }
    });
    document.addEventListener('mouseout', (e) => {
      if (e.target.closest && e.target.closest(interactiveSelector)) {
        el.classList.remove('is-large');
      }
    });

    const tick = () => {
      x += (targetX - x) * 0.2;
      y += (targetY - y) * 0.2;
      const h = HALF();
      el.style.transform = `translate3d(${x - h}px, ${y - h}px, 0)`;
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  })();
</script>
